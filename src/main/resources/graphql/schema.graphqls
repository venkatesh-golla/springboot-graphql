type Query{
    books: [Book]
    bookById(id:Int): Book
    user(id:ID!) : User
}

type Book{
    id: ID
    name: String
    pageCount: Int
    author: Author
}

type Author{
    id: ID
    name: String
}

type User{
    id: ID!
    name: String
    orders: [Order]
    payments: [Payment]
}

type Order{
    id: ID!
    amount: Float
}

type Payment{
    id: ID!
    amount: Float
}